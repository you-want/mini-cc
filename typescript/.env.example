# 选择你要使用的提供商: 'anthropic' 或 'openai'
PROVIDER=anthropic

# 如果使用 Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key
# MODEL_NAME=claude-3-7-sonnet-20250219

# ==========================================
# 如果使用 OpenAI 兼容接口（如 DeepSeek, 通义千问, Kimi, 或者 OpenAI 本身）
# ==========================================
# PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# 
# 如果是第三方兼容接口，配置其对应的 baseUrl。例如 DeepSeek:
# OPENAI_BASE_URL=https://api.deepseek.com
# 
# 指定调用的模型名称。例如 DeepSeek:
# MODEL_NAME=deepseek-chat
