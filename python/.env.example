# .env 配置文件示例
# 请将此文件复制为 .env，并填入你自己的配置

# 默认使用的模型提供商 (openai 或 anthropic)
PROVIDER=openai

# --- OpenAI 或兼容接口配置 ---
OPENAI_API_KEY=sk-xxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1  # 可选，用于 DeepSeek/Qwen 等兼容接口
MODEL_NAME=deepseek-coder

# --- Anthropic 官方接口配置 ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxx
# MODEL_NAME=claude-3-7-sonnet-20250219
